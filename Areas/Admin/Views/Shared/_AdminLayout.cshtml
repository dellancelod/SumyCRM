<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Адмін-панель - GiftsBakery</title>

    @await Html.PartialAsync("MetatagsPartial")
    @await Html.PartialAsync("CssPartial")
</head>

<body>
    <div id="call-popup-overlay" style="display:none;">
        <div id="call-popup-box">
            <div id="call-popup-title">Вхідний дзвінок на оператора</div>
            <div class="call-popup-row">
                <strong>Номер:</strong>
                <span id="call-popup-phone"></span>
            </div>
            <div class="call-popup-row">
                <strong>Абонент:</strong>
                <span id="call-popup-name"></span>
            </div>
            <div class="call-popup-actions">
                <button type="button" id="call-popup-create-request" class="btn btn-primary">
                    Створити звернення
                </button>
                <button type="button" id="call-popup-close" class="btn btn-secondary">
                    Закрити
                </button>
            </div>
        </div>
    </div>

    <div class="wrapper">
        @await Html.PartialAsync("_SideBarLayout")
        <div id="content">
            @await Html.PartialAsync("_TopBarLayout")
            <div id="scrollable-content" class="p-3 admin-body">
                @RenderBody()
            </div>
        </div>

        @await Html.PartialAsync("ScriptsPartial")
        @await RenderSectionAsync("Scripts", required: false)
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

    <style>
        #call-popup-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.35);
            z-index: 99999;
        }

        #call-popup-box {
            position: fixed;
            top: 20px;
            right: 20px;
            width: 420px;
            max-width: calc(100vw - 40px);
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 12px 32px rgba(0,0,0,0.25);
            padding: 18px;
            z-index: 100000;
        }

        #call-popup-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .call-popup-row {
            margin-bottom: 8px;
            font-size: 16px;
        }

        .call-popup-actions {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }
    </style>

    <script>
        (function () {
            const overlay = document.getElementById("call-popup-overlay");
            const phoneEl = document.getElementById("call-popup-phone");
            const nameEl = document.getElementById("call-popup-name");
            const closeEl = document.getElementById("call-popup-close");
            const createRequestEl = document.getElementById("call-popup-create-request");

            let currentPopupData = null;

            if (!overlay || !phoneEl || !nameEl || !closeEl || !createRequestEl || typeof signalR === "undefined")
                return;

            function showPopup(data) {
                currentPopupData = data || {};

                phoneEl.textContent = currentPopupData.phone || "";
                nameEl.textContent = currentPopupData.name || "Невідомий абонент";

                overlay.style.display = "block";
            }

            function hidePopup() {
                overlay.style.display = "none";
            }

            closeEl.addEventListener("click", hidePopup);

            overlay.addEventListener("click", function (e) {
                if (e.target === overlay) hidePopup();
            });

            createRequestEl.addEventListener("click", function () {
                if (!currentPopupData) return;

                const params = new URLSearchParams();

                if (currentPopupData.abonentId)
                    params.append("abonentId", currentPopupData.abonentId);

                if (currentPopupData.phone)
                    params.append("caller", currentPopupData.phone);

                if (currentPopupData.name)
                    params.append("name", currentPopupData.name);

                window.location.href = "/Admin/Requests/Edit?" + params.toString();
            });

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/call-notifications")
                .withAutomaticReconnect()
                .build();

            connection.on("IncomingOperatorTransfer", function (data) {
                showPopup(data);
            });

            connection.start().catch(function (err) {
                console.error("SignalR connection error:", err);
            });
        })();
    </script>
</body>
</html>