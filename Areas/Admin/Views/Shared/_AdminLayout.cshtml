<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Адмін-панель - GiftsBakery</title>

    @await Html.PartialAsync("MetatagsPartial")
    @await Html.PartialAsync("CssPartial")
</head>

<div id="call-popup-overlay" style="display:none;">
    <div id="call-popup-box">
        <div id="call-popup-title">Вхідний дзвінок на оператора</div>
        <div class="call-popup-row">
            <strong>Номер:</strong>
            <span id="call-popup-phone"></span>
        </div>
        <div class="call-popup-row">
            <strong>Абонент:</strong>
            <span id="call-popup-name"></span>
        </div>
        <div class="call-popup-actions">
            <a id="call-popup-open" href="#" class="btn btn-primary">Відкрити абонента</a>
            <button type="button" id="call-popup-close" class="btn btn-secondary">Закрити</button>
        </div>
    </div>
</div>

<body>
    <div class="wrapper">
        @await Html.PartialAsync("_SideBarLayout")
        <div id="content">
            @await Html.PartialAsync("_TopBarLayout")
            <div id="scrollable-content" class=" p-3 admin-body">
                @RenderBody()
            </div>
        </div>

        @await Html.PartialAsync("ScriptsPartial")
        @await RenderSectionAsync("Scripts", required: false)
    </div>
</body>
</html>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

<style>
    #call-popup-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.35);
        z-index: 99999;
    }

    #call-popup-box {
        position: fixed;
        top: 20px;
        right: 20px;
        width: 420px;
        max-width: calc(100vw - 40px);
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.25);
        padding: 18px;
        z-index: 100000;
    }

    #call-popup-title {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .call-popup-row {
        margin-bottom: 8px;
        font-size: 16px;
    }

    .call-popup-actions {
        display: flex;
        gap: 10px;
        margin-top: 16px;
    }
</style>
<script>
    (function () {
        const overlay = document.getElementById("call-popup-overlay");
        const phoneEl = document.getElementById("call-popup-phone");
        const nameEl = document.getElementById("call-popup-name");
        const openEl = document.getElementById("call-popup-open");
        const closeEl = document.getElementById("call-popup-close");

        if (!overlay || !phoneEl || !nameEl || !openEl || !closeEl || typeof signalR === "undefined")
            return;

        function showPopup(data) {
            phoneEl.textContent = data.phone || "";
            nameEl.textContent = data.name || "Невідомий абонент";

            if (data.abonentId) {
                openEl.style.display = "inline-block";
                openEl.href = "/Admin/Abonents/Edit/" + data.abonentId;
            } else {
                openEl.style.display = "none";
                openEl.removeAttribute("href");
            }

            overlay.style.display = "block";
        }

        function hidePopup() {
            overlay.style.display = "none";
        }

        closeEl.addEventListener("click", hidePopup);
        overlay.addEventListener("click", function (e) {
            if (e.target === overlay) hidePopup();
        });

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/call-notifications")
            .withAutomaticReconnect()
            .build();

        connection.on("IncomingOperatorTransfer", function (data) {
            showPopup(data);
        });

        connection.start().catch(function (err) {
            console.error("SignalR connection error:", err);
        });
    })();
</script>